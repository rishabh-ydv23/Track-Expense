# Production Environment - AWS Deployment
NODE_ENV=production
PORT=4000

# MongoDB Atlas Connection
# Get this from MongoDB Atlas Dashboard
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/trackexpense?retryWrites=true&w=majority

# JWT Secret - Generate strong random key
# Use: openssl rand -base64 32
JWT_SECRET=your-production-secret-key-min-32-characters-long

# CORS - Set to your actual domain
CORS_ORIGIN=https://yourdomain.com

# Enable when running behind AWS Load Balancer
TRUST_PROXY=1
